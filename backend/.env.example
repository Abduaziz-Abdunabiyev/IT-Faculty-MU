# Copy to backend/.env for local dev, and set the SAME keys as env vars on Railway.

# --- Core Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False

# Hosts / CORS / CSRF are OPTIONAL — defaults already allow any *.up.railway.app
# backend and any *.vercel.app frontend. Only set these to pin exact domains.
# Comma-separated.
# ALLOWED_HOSTS=localhost,127.0.0.1,.up.railway.app
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
# CSRF_TRUSTED_ORIGINS=https://your-backend.up.railway.app,https://your-frontend.vercel.app

# --- Database (MySQL) ---
DB_NAME=it_department_db
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- Cloudinary (persistent media storage) ---
# Get these from the Cloudinary dashboard (Programmable Media > Dashboard).
# When all three are set, uploads go to Cloudinary; if left blank, Django
# falls back to local filesystem storage (fine for local dev only).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
